{
  "dashboard": {
    "id": null,
    "uid": "hsk-consent-ops",
    "title": "HSK - Consent Operations",
    "tags": ["hsk", "consent", "operations"],
    "timezone": "utc",
    "schemaVersion": 36,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Consents Granted (24h)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(hsk_consent_granted_total[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {"unit": "short"}
        }
      },
      {
        "id": 2,
        "title": "Consents Revoked (24h)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
        "targets": [
          {
            "expr": "sum(increase(hsk_consent_revoked_total[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "steps": [
                {"color": "green", "value": 0},
                {"color": "yellow", "value": 100},
                {"color": "red", "value": 1000}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Active Consents",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
        "targets": [
          {
            "expr": "hsk_consent_active_total",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        }
      },
      {
        "id": 4,
        "title": "Verification Success Rate (%)",
        "type": "gauge",
        "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "(sum(rate(hsk_verification_success_total[5m])) / sum(rate(hsk_verification_total[5m]))) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 95},
                {"color": "green", "value": 99}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Consent Operations Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 16, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(hsk_consent_granted_total[5m]))",
            "legendFormat": "Granted",
            "refId": "A"
          },
          {
            "expr": "sum(rate(hsk_consent_revoked_total[5m]))",
            "legendFormat": "Revoked",
            "refId": "B"
          },
          {
            "expr": "sum(rate(hsk_consent_verified_total[5m]))",
            "legendFormat": "Verified",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "min": 0,
            "custom": {"lineWidth": 2, "fillOpacity": 20}
          }
        }
      },
      {
        "id": 6,
        "title": "Consent by Purpose",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "sum by (purpose) (hsk_consent_by_purpose)",
            "legendFormat": "{{purpose}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right"}
        }
      },
      {
        "id": 7,
        "title": "Consent by Data Category",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 4},
        "targets": [
          {
            "expr": "sum by (category) (hsk_consent_by_category)",
            "legendFormat": "{{category}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right"}
        }
      },
      {
        "id": 8,
        "title": "Verification Latency (ms)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(hsk_verification_duration_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "P50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(hsk_verification_duration_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "P95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(hsk_verification_duration_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "P99",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "min": 0,
            "custom": {"lineWidth": 2}
          }
        }
      },
      {
        "id": 9,
        "title": "Failed Verifications",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "sum(rate(hsk_verification_failed_total[5m])) by (reason)",
            "legendFormat": "{{reason}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "custom": {"lineWidth": 2, "fillOpacity": 30}
          }
        }
      },
      {
        "id": 10,
        "title": "Consent Ledger Growth",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "hsk_ledger_total_entries",
            "legendFormat": "Total Entries",
            "refId": "A"
          },
          {
            "expr": "hsk_ledger_current_hash_chain_length",
            "legendFormat": "Hash Chain Length",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {"lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 11,
        "title": "Merkle Tree Operations",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "targets": [
          {
            "expr": "sum(rate(hsk_merkle_tree_build_total[5m]))",
            "legendFormat": "Tree Builds",
            "refId": "A"
          },
          {
            "expr": "sum(rate(hsk_merkle_proof_generated_total[5m]))",
            "legendFormat": "Proofs Generated",
            "refId": "B"
          },
          {
            "expr": "sum(rate(hsk_merkle_proof_verified_total[5m]))",
            "legendFormat": "Proofs Verified",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "custom": {"lineWidth": 2}
          }
        }
      },
      {
        "id": 12,
        "title": "Batch Processing",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
        "targets": [
          {
            "expr": "hsk_batch_size",
            "legendFormat": "Batch Size",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(hsk_batch_processing_duration_seconds_bucket[5m])) by (le)) * 1000",
            "legendFormat": "P95 Processing Time",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {"lineWidth": 2, "fillOpacity": 20}
          }
        }
      },
      {
        "id": 13,
        "title": "Geographic Distribution",
        "type": "geomap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
        "targets": [
          {
            "expr": "sum by (latitude, longitude) (hsk_consent_by_location)",
            "format": "table",
            "refId": "A"
          }
        ],
        "options": {
          "view": {
            "allLayers": true,
            "lat": 20,
            "lon": 0,
            "zoom": 2
          }
        }
      }
    ]
  }
}
